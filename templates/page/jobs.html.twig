{% extends 'base.html.twig' %}
{% block title %}All Jobs{% endblock %}
{% block body %}

<div class="container py-5">

    {# ── FILTER BAR ── #}
    <form method="GET" action="{{ path('app_jobs') }}" class="card shadow-sm p-4 mb-4">
        <div class="row g-3 align-items-end">

            {# Keyword #}
            <div class="col-md-3">
                <label class="form-label fw-semibold">Keyword</label>
                <input type="text" name="q" class="form-control"
                       placeholder="Title, company, city..."
                       value="{{ query ?? '' }}">
            </div>

            {# Category #}
            <div class="col-md-2">
                <label class="form-label fw-semibold">Category</label>
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    {% for cat in categories %}
                        <option value="{{ cat['id'] }}"
                            {{ category == cat['id']|default('') ? 'selected' : '' }}>
                            {{ cat['name'] }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# Country #}
            <div class="col-md-2">
                <label class="form-label fw-semibold">Country</label>
                <select name="country" class="form-select">
                    <option value="">All Countries</option>
                    {% for c in countries %}
                        <option value="{{ c }}" {{ country == c ? 'selected' : '' }}>
                            {{ c }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            {# Salary Min #}
            <div class="col-md-2">
                <label class="form-label fw-semibold">Min Salary ($)</label>
                <input type="number" name="salary_min" class="form-control"
                       placeholder="e.g. 40000"
                       value="{{ salaryMin ?? '' }}">
            </div>

            {# Salary Max #}
            <div class="col-md-2">
                <label class="form-label fw-semibold">Max Salary ($)</label>
                <input type="number" name="salary_max" class="form-control"
                       placeholder="e.g. 120000"
                       value="{{ salaryMax ?? '' }}">
            </div>

            {# Buttons #}
            <div class="col-md-1 d-flex gap-2">
                <button type="submit" class="btn btn-jobstock w-100">
                    <i class="bi bi-search"></i>
                </button>
                <a href="{{ path('app_jobs') }}" class="btn btn-outline-secondary w-100">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>

        </div>
    </form>

    {# Result count #}
    <p class="text-muted mb-3">
        Showing <strong>{{ jobs|length }}</strong> of <strong>{{ total }}</strong> jobs
    </p>

    {# ── JOB CARDS ── #}
    <div class="row g-4">
        {% if jobs is empty %}
            <div class="col-12 text-center">
                <p class="text-muted fs-5">No jobs found matching your filters.</p>
            </div>
        {% else %}
            {% for job in jobs %}
                <div class="col-md-6">
                    <div class="card job-card h-100 shadow-sm rounded">
                        <div class="card-body p-3 d-flex flex-column">
                            <div class="d-flex mb-3">
                                <div class="me-3 d-flex align-items-center">
                                    <img src="{{ asset('images/' ~ job.company.logo|default('default.png')) }}"
                                         alt="{{ job.company.name }}"
                                         style="width:60px; height:60px; object-fit:contain; border-radius:8px;">
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <div>
                                            <h5 class="card-title mb-1">{{ job.title }}</h5>
                                            <small class="text-muted">
                                                {{ job.company.name }} • {{ job.city }}, {{ job.country }}
                                            </small>
                                        </div>
                                        <div class="d-flex flex-column align-items-end gap-1">
                                          {% if job.remoteAllowed %}
                                            <span class="badge badge-remote" style="min-width:80px; text-align:center;">REMOTE</span>
                                          {% else %}
                                            <span class="badge badge-onsite" style="min-width:80px; text-align:center;">ONSITE</span>
                                          {% endif %}

                                          {% if job.jobType %}
                                            <span class="badge" style="background-color:#11999e; min-width:80px; text-align:center;">{{ job.jobType.name }}</span>
                                          {% endif %}
                                        </div>
                                    </div>
                                    {% if job.salaryMin and job.salaryMax %}
                                        <p class="mb-1 text-success">
                                            ${{ job.salaryMin|number_format(0, '.', ',') }} – ${{ job.salaryMax|number_format(0, '.', ',') }}
                                        </p>
                                    {% endif %}
                                </div>
                            </div>
                            <p class="description mb-3 flex-grow-1">
                                {{ job.description|slice(0, 140) ~ '...' }}
                            </p>
                            <a href="{{ app.user ? path('app_jobapplication', {'id': job.id}) : '#' }}"
                               class="btn btn-jobstock w-100 {% if not app.user %}disabled{% endif %}">
                                <i class="bi bi-send me-1"></i>
                                {% if app.user %}Apply Now{% else %}Login to Apply{% endif %}
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>

    {# ── PAGINATION ── #}
    {% if totalPages > 1 %}
        <nav class="mt-5 d-flex justify-content-center">
            <ul class="pagination">

                {# Prev #}
                <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_jobs', app.request.query.all|merge({'page': currentPage - 1})) }}">
                        &laquo;
                    </a>
                </li>

                {# Page numbers #}
                {% for p in 1..totalPages %}
                    <li class="page-item {{ p == currentPage ? 'active' : '' }}">
                        <a class="page-link" href="{{ path('app_jobs', app.request.query.all|merge({'page': p})) }}">
                            {{ p }}
                        </a>
                    </li>
                {% endfor %}

                {# Next #}
                <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                    <a class="page-link" href="{{ path('app_jobs', app.request.query.all|merge({'page': currentPage + 1})) }}">
                        &raquo;
                    </a>
                </li>

            </ul>
        </nav>
    {% endif %}

</div>
{% endblock %}