{% extends 'base.html.twig' %}

{% block title %}Apply for {{ job.title }}{% endblock %}

{% block body %}
<div class="container py-5">
    <h2>Apply for: {{ job.title }}</h2>
    <p><strong>Company:</strong> {{ job.company.name }}</p>
    <p><strong>Location:</strong> {{ job.city }}, {{ job.country }}</p>

    {# Display flash messages #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}

    <form method="POST" action="{{ path('app_job_application', {'id': job.id}) }}" 
          class="card p-4 shadow-sm mt-3" enctype="multipart/form-data">

        <div class="mb-3">
            <label class="form-label">Your Cover Letter</label>
            <textarea name="message" class="form-control" rows="5" required></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Upload Resume (optional)</label>
            <input type="file" name="resume" class="form-control">
        </div>

        <button type="submit" class="btn btn-jobstock">Submit Application</button>
    </form>
</div>
{% endblock %}