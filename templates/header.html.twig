
<nav class="navbar">
    <div class="navdiv">
        <!-- Logo Left -->
        <div class="logo">
            <a href="{{ path('app_home') }}">
                <img src="{{ asset('images/logo-jobiz.png') }}" alt="Jobiz" class="logo">
            </a>
        </div>

        <!-- Navigation Links Center/Right -->
<ul class="nav-links">
    <li><a href="{{ path('app_home') }}" class="{{ app.request.get('_route') == 'app_home' ? 'active' : '' }}">Home</a></li>
    <li><a href="{{ path('app_about') }}" class="{{ app.request.get('_route') == 'app_about' ? 'active' : '' }}">About</a></li>
    <li><a href="{{ path('app_jobs') }}" class="{{ app.request.get('_route') == 'app_jobs' ? 'active' : '' }}">Job List</a></li>
    <li><a href="{{ path('app_contact') }}" class="{{ app.request.get('_route') == 'app_contact' ? 'active' : '' }}">Contact</a></li>
</ul>

        <!-- Buttons Right -->
<div class="nav-buttons">
    {% if app.user %}
        <span style="margin-right:10px; color:white; margin-top:10px;"  >Welcome, {{ app.user.firstName }}!</span>
        <button style="color:white;" class="btn-nav" onclick="window.location.href='{{ path('app_logout') }}'">Logout</button>
    {% else %}
        <button style="color:white;" class="btn-nav" onclick="window.location.href='{{ path('app_login') }}'">Login</button>
        <button style="color:white;" class="btn-nav" onclick="window.location.href='{{ path('app_register') }}'">Sign Up</button>
    {% endif %}
</div>
    </div>
</nav>
